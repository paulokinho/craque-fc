{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "rootDir": "../../",
    "baseUrl": "."
  },
  "include": ["src/**/*", "../../apps/api/src/**/*"],
  "exclude": ["node_modules", "dist"]
}
